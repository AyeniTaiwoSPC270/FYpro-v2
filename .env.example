# FYPro — required environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase (frontend-safe)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase — server-side only (used by Vercel serverless functions via process.env)
# SUPABASE_URL must be set separately from VITE_SUPABASE_URL — the VITE_ prefix is
# stripped by Vite at build time and is not available as process.env.SUPABASE_URL in
# serverless functions.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — server-side only
ANTHROPIC_API_KEY=

# Paystack
VITE_PAYSTACK_PUBLIC_KEY=
# PAYSTACK_PUBLIC_KEY is the non-VITE server-side variant returned by /api/payments?action=initiate
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# Resend — transactional email, server-side only
RESEND_API_KEY=

# ElevenLabs TTS
EL_API_KEY=

# Upstash Redis — rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Daily spend cap in USD (e.g. 10)
DAILY_CAP_USD=

# Sentry — error monitoring, frontend-safe
VITE_SENTRY_DSN=
# Sentry webhook secret — server-side only, required for /api/sentry-webhook
SENTRY_WEBHOOK_SECRET=
# Sentry API — server-side only, required for /api/admin?action=system_logs
# Create an internal integration token at sentry.io/settings/{org}/developer-settings/
# SENTRY_ORG and SENTRY_PROJECT are the slugs from your Sentry project URL:
#   https://sentry.io/settings/{SENTRY_ORG}/projects/{SENTRY_PROJECT}/
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Admin — server-side only. Never create VITE_ADMIN_EMAIL (would expose admin email in frontend JS bundle).
ADMIN_EMAIL=

# PostHog analytics — frontend-safe
VITE_POSTHOG_KEY=

# Telegram admin alerts — server-side only
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Required: set when registering the webhook via Telegram API setWebhook (secret_token field).
# If not set, the bot rejects ALL inbound updates (fails closed).
TELEGRAM_WEBHOOK_SECRET=

# VAPID keys for Web Push notifications
# Generate with: node -e "const w=require('web-push'); const k=w.generateVAPIDKeys(); console.log('PUBLIC:', k.publicKey, '\nPRIVATE:', k.privateKey)"
# VAPID_PUBLIC_KEY and VAPID_PRIVATE_KEY are server-only (used by api/notify.js)
# VITE_VAPID_PUBLIC_KEY equals VAPID_PUBLIC_KEY — exposed to the frontend for push subscription
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VITE_VAPID_PUBLIC_KEY=

# App environment — set to "staging" in the Vercel staging project only.
# Leave unset in production. Controls the Sentry environment tag and the staging banner.
VITE_APP_ENV=
