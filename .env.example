# FYPro — required environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase (frontend-safe)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase service role — server-side only, never in frontend code
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — server-side only
ANTHROPIC_API_KEY=

# Paystack
VITE_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# Gmail SMTP — transactional email, server-side only
GMAIL_USER=team.fypro@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# ElevenLabs TTS
EL_API_KEY=

# Upstash Redis — rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Daily spend cap in USD (e.g. 10)
DAILY_CAP_USD=

# Admin
ADMIN_EMAIL=
VITE_ADMIN_EMAIL=
