{
  "functions": {
    "api/claude.js": {
      "maxDuration": 60
    },
    "api/speak.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/admin/alert-check",
      "schedule": "0 * * * *"
    }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}